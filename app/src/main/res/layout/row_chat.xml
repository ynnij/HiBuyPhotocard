<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <!-- A CardView that contains a TextView -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <ImageView
            android:id="@+id/ImageView_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/login_btn" />

        <TextView
            android:id="@+id/TextView_nickname"
            android:layout_width="40dp"
            android:layout_height="13dp"
            android:layout_alignStart="@id/ImageView_profile"
            android:layout_marginStart="42dp"
            android:layout_toEndOf="@+id/ImageView_profile"
            android:textSize="12sp" />


        <TextView
            android:id="@+id/TextView_timestamp"
            android:layout_width="200dp"
            android:layout_height="13dp"
            android:layout_alignStart="@id/TextView_nickname"
            android:layout_marginStart="40dp"
            android:layout_toEndOf="@id/TextView_nickname"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/TextView_msg"
            android:layout_width="match_parent"
            android:layout_height="21dp"
            android:layout_alignTop="@id/TextView_nickname"
            android:layout_marginStart="42dp"
            android:layout_marginTop="13dp"
            android:textSize="20sp" />

    </RelativeLayout>

</LinearLayout>